# ===========================================
# 첫 클론 시 설정 방법
# ===========================================
# 1. 이 파일을 env_defaults.env로 복사
#    Windows: copy assets\env_defaults.env.example assets\env_defaults.env
#    Mac/Linux: cp assets/env_defaults.env.example assets/env_defaults.env
#
# 2. 아래 값에 키 입력 후 저장
#
# 3. 키 발급처
#    - 카카오: https://developers.kakao.com/console/app
#    - PortOne: https://portone.io 콘솔
# 보안을 위해 키값은 업로드 하지 않았습니다. 발급받으시거나 제작자에게 키값 요청해주세요 
# ===========================================

KAKAO_MAP_API_KEY=
KAKAO_REST_API_KEY=

PORTONE_STORE_ID=
PORTONE_CHANNEL_KEY=
# 테스트용: PORTONE_USE_TEST_CHANNEL=true (100원 인증 시 테스트 카드 사용)
PORTONE_CHANNEL_KEY_KAKAOPAY=
PORTONE_CLIENT_KEY=
